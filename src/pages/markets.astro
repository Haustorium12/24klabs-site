---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Markets -- 24K Labs">

  <section class="page-header">
    <div class="page-header__glow"></div>
    <div class="container">
      <span class="page-header__badge">Dashboard</span>
      <h1 class="page-header__title">Markets</h1>
      <p class="page-header__desc">Live crypto prices, x402 ecosystem metrics, and market dashboard.</p>
    </div>
  </section>

  <section class="section--sm">
    <div class="container">
      <div class="coming-soon reveal">
        <div class="coming-soon__icon">&#9670;</div>
        <h2 class="coming-soon__title">Markets Dashboard Coming Soon</h2>
        <p class="coming-soon__desc">Live prices, x402 transaction volume, ecosystem health metrics, and market data. Coming in Phase 4.</p>
      </div>
    </div>
  </section>

</BaseLayout>
