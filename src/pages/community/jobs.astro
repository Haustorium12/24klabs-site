---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Job Board -- 24K Labs">

  <section class="page-header">
    <div class="page-header__glow"></div>
    <div class="container">
      <span class="page-header__badge">Careers</span>
      <h1 class="page-header__title">Job Board</h1>
      <p class="page-header__desc">x402 and crypto roles from across the ecosystem.</p>
    </div>
  </section>

  <section class="section--sm">
    <div class="container">
      <div class="coming-soon reveal">
        <div class="coming-soon__icon">&#9881;</div>
        <h2 class="coming-soon__title">Job Board Coming Soon</h2>
        <p class="coming-soon__desc">We're building an aggregated job board for x402 and crypto roles from Foundation members and ecosystem partners. Check back soon.</p>
      </div>
    </div>
  </section>

</BaseLayout>
