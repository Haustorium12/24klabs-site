---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Partners -- 24K Labs">

  <section class="page-header">
    <div class="page-header__glow"></div>
    <div class="container">
      <span class="page-header__badge">Ecosystem</span>
      <h1 class="page-header__title">Partners</h1>
      <p class="page-header__desc">Organizations and protocols building on x402.</p>
    </div>
  </section>

  <section class="section--sm">
    <div class="container">
      <div class="coming-soon reveal">
        <div class="coming-soon__icon">&#10070;</div>
        <h2 class="coming-soon__title">Partner Directory Coming Soon</h2>
        <p class="coming-soon__desc">We're onboarding launch partners now. Interested in building on x402? Reach out on Discord or GitHub.</p>
      </div>
    </div>
  </section>

</BaseLayout>
