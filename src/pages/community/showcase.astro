---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Showcase -- 24K Labs">

  <section class="page-header">
    <div class="page-header__glow"></div>
    <div class="container">
      <span class="page-header__badge">Built With 24K Labs</span>
      <h1 class="page-header__title">Showcase</h1>
      <p class="page-header__desc">Projects and integrations powered by 24K Labs services.</p>
    </div>
  </section>

  <section class="section--sm">
    <div class="container">
      <div class="coming-soon reveal">
        <div class="coming-soon__icon">&#9889;</div>
        <h2 class="coming-soon__title">Showcase Coming Soon</h2>
        <p class="coming-soon__desc">Shipped something with 24K Labs? We want to feature it. Submit your project on GitHub and we'll add it here.</p>
      </div>
    </div>
  </section>

</BaseLayout>
