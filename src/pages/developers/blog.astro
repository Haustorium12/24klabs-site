---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Blog -- 24K Labs">

  <section class="page-header">
    <div class="page-header__glow"></div>
    <div class="container">
      <span class="page-header__badge">From the Lab</span>
      <h1 class="page-header__title">Blog</h1>
      <p class="page-header__desc">Tutorials, product deep-dives, and research from the 24K Labs team.</p>
    </div>
  </section>

  <section class="section--sm">
    <div class="container">

      <div class="grid-3">

        <a href="/developers/blog/x402-payment-guide" class="card blog-card reveal">
          <span class="badge badge--haiku">Tutorial</span>
          <h3 class="blog-card__title">How to Pay for AI Services with USDC in One HTTP Call</h3>
          <p class="blog-card__excerpt">Walk through the full x402 payment flow from first request to final result. Python examples and the 3-step HTTP flow explained.</p>
          <span class="blog-card__meta">April 8, 2026 &middot; 8 min read</span>
        </a>

        <a href="/developers/blog/code-review-per-pr" class="card blog-card reveal">
          <span class="badge badge--sonnet">Product</span>
          <h3 class="blog-card__title">Code Review API: Pay Per PR, Not Per Seat</h3>
          <p class="blog-card__excerpt">Why per-request pricing makes more sense for code review than annual subscriptions. The math for solo devs and small teams.</p>
          <span class="blog-card__meta">April 8, 2026 &middot; 7 min read</span>
        </a>

        <a href="/developers/blog/three-layers-ai-memory" class="card blog-card reveal">
          <span class="badge badge--opus">Research</span>
          <h3 class="blog-card__title">The Three Layers of AI Memory</h3>
          <p class="blog-card__excerpt">Capture, cognition, reinforcement. Why your coding assistant forgets everything and what it takes to fix it.</p>
          <span class="blog-card__meta">April 8, 2026 &middot; 8 min read</span>
        </a>

        <a href="/developers/blog/what-is-x402" class="card blog-card reveal">
          <span class="badge badge--gold">Explainer</span>
          <h3 class="blog-card__title">x402 Explained: The HTTP Status Code That Took 35 Years to Ship</h3>
          <p class="blog-card__excerpt">The history of HTTP 402 -- reserved in 1991, ignored for decades, now activated by Coinbase and the Linux Foundation.</p>
          <span class="blog-card__meta">April 9, 2026 &middot; 7 min read</span>
        </a>

        <a href="/developers/blog/building-24k-labs" class="card blog-card reveal">
          <span class="badge badge--gold">Story</span>
          <h3 class="blog-card__title">Building 24K Labs: From a Pawn Shop to the x402 Economy</h3>
          <p class="blog-card__excerpt">The founder story. From building AI tools for a Kensington pawn shop to running six services on the x402 protocol.</p>
          <span class="blog-card__meta">April 9, 2026 &middot; 6 min read</span>
        </a>

        <a href="/developers/blog/security-audit-owasp" class="card blog-card reveal">
          <span class="badge badge--sonnet">Product</span>
          <h3 class="blog-card__title">Automated OWASP Top 10 Scanning: $25 Per Audit</h3>
          <p class="blog-card__excerpt">OWASP Top 10 analysis with CVSS scoring and remediation steps. $25 per scan vs. $200+/month subscriptions.</p>
          <span class="blog-card__meta">April 9, 2026 &middot; 6 min read</span>
        </a>

        <a href="/developers/blog/mcp-blueprint-service" class="card blog-card reveal">
          <span class="badge badge--sonnet">Product</span>
          <h3 class="blog-card__title">Design an MCP Server in 60 Seconds for $50</h3>
          <p class="blog-card__excerpt">Describe what you want, get a complete MCP server blueprint -- tool definitions, implementation, deployment config, and docs.</p>
          <span class="blog-card__meta">April 9, 2026 &middot; 6 min read</span>
        </a>

      </div>

      <p class="blog-footer reveal">Follow us on <a href="https://github.com/24klabs" target="_blank" rel="noopener">GitHub</a> for updates.</p>

    </div>
  </section>

</BaseLayout>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }
  .blog-card:hover {
    color: inherit;
  }
  .blog-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.4;
  }
  .blog-card__excerpt {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.7;
    flex: 1;
  }
  .blog-card__meta {
    color: var(--text-dim);
    font-size: 0.8rem;
  }
  .blog-footer {
    text-align: center;
    color: var(--text-muted);
    margin-top: 60px;
    font-size: 0.95rem;
  }
</style>
