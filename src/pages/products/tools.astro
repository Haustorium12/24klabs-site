---
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = [
  {
    name: '24klabs-mcp',
    description: 'AI code analysis MCP server with 6 tools powered by Claude. Works with Claude Code, Cursor, and any MCP-compatible client. Drop-in code review in your IDE.',
    tags: ['MCP', 'AI', 'Developer Tools'],
    github: 'https://github.com/Haustorium12/24klabs-mcp',
  },
  {
    name: '24klabs-action',
    description: 'GitHub Action for automated code review. Security, performance, and architecture analysis on every PR, powered by Claude. No API key setup required.',
    tags: ['GitHub Action', 'CI/CD', 'Code Review'],
    github: 'https://github.com/Haustorium12/24klabs-action',
  },
  {
    name: 'memory-v3',
    description: 'Brain-inspired persistent memory for AI coding assistants. MAGMA multi-graph architecture, 3-stage retrieval, ACT-R activation scoring, and sleep consolidation. Successor to memory-v2.',
    tags: ['AI Memory', 'MCP', 'Open Source'],
    github: 'https://github.com/Haustorium12/memory-v3',
  },
  {
    name: 'memory-v2',
    description: 'Persistent memory system for AI agents with hybrid BM25+vector search, ACT-R activation scoring, FadeMem decay, and knowledge graphs. Production-stable.',
    tags: ['AI Memory', 'MCP', 'Open Source'],
    github: 'https://github.com/Haustorium12/memory-v2',
  },
  {
    name: 'the-24k-vault',
    description: 'The curated Obsidian ecosystem. Plugins, themes, tools, and resources -- handpicked for power users. Community-maintained and continuously updated.',
    tags: ['Obsidian', 'Productivity', 'Community'],
    github: 'https://github.com/Haustorium12/the-24k-vault',
  },
  {
    name: 'gold-402',
    description: 'The gold standard for x402 resources. 300+ projects, SDKs, tools, facilitators, and ecosystem data for the HTTP 402 Payment Required protocol. Curated by 24K Labs.',
    tags: ['x402', 'Directory', 'Resources'],
    github: 'https://github.com/Haustorium12/gold-402',
  },
  {
    name: 'awesome-claude-code',
    description: 'A curated list of skills, hooks, slash-commands, agent orchestrators, applications, and plugins for Claude Code by Anthropic.',
    tags: ['Claude Code', 'Awesome List', 'Community'],
    github: 'https://github.com/Haustorium12/awesome-claude-code',
  },
];
---

<BaseLayout title="Open Source Tools -- 24K Labs" description="Open source tools and projects from 24K Labs. AI agent memory, x402 resources, weather trading bots, and more.">

  <section class="page-header">
    <div class="page-header__glow"></div>
    <div class="container">
      <span class="page-header__badge">Open Source</span>
      <h1 class="page-header__title">Tools</h1>
      <p class="page-header__desc">
        Open source projects from 24K Labs. Built in public, free to use.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="tools-grid">
        {tools.map(tool => (
          <div class="card tool-card reveal">
            <div class="tool-card__header">
              <h2 class="tool-card__name">{tool.name}</h2>
              <a href={tool.github} target="_blank" rel="noopener" class="btn btn--outline btn--sm">
                GitHub &#8599;
              </a>
            </div>
            <p class="tool-card__desc">{tool.description}</p>
            <div class="tool-card__tags">
              {tool.tags.map(tag => (
                <span class="badge badge--gold">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--bg-surface);">
    <div class="container">
      <div class="coming-soon reveal">
        <div class="coming-soon__icon">&#128736;</div>
        <h2 class="coming-soon__title">More tools coming</h2>
        <p class="coming-soon__desc">
          We're building more open source tools for the x402 ecosystem.
          Watch our GitHub for new releases.
        </p>
        <div style="margin-top: 24px;">
          <a href="https://github.com/Haustorium12" target="_blank" rel="noopener" class="btn btn--primary">
            Follow on GitHub &#8599;
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .tools-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .tool-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    flex-wrap: wrap;
    gap: 12px;
  }

  .tool-card__name {
    font-size: 1.4rem;
    font-weight: 700;
    font-family: var(--mono);
    letter-spacing: -0.01em;
  }

  .tool-card__desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .tool-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
</style>
